<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto backup (pre-Android 12 cloud backup): exclude prefs that hold LAN auth tokens
  and the op-log DB (may contain bind/API details).
  https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <exclude domain="sharedpref" path="matrix_prefs.xml" />
    <exclude domain="database" path="matrixclock.db" />
</full-backup-content>
