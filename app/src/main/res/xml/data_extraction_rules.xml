<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ cloud backup & device-to-device transfer: same exclusions as backup_rules.xml.
  https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="matrix_prefs.xml" />
        <exclude domain="database" path="matrixclock.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="matrix_prefs.xml" />
        <exclude domain="database" path="matrixclock.db" />
    </device-transfer>
</data-extraction-rules>
