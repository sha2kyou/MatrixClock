# MatrixClock admin (Vite dev server only)
# Copy to ".env" in this folder, then run: npm run dev
#
# Proxies browser requests from /api to the phone running MatrixClock.
# Use the IP shown in the app (same Wi‑Fi as your PC), e.g.:
MATRIX_PROXY_TARGET=http://192.168.1.10:6574

# Optional: if hot reload misbehaves on your LAN, try:
# DISABLE_HMR=true
